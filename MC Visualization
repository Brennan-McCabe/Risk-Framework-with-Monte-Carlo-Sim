import numpy as np
import matplotlib.pyplot as plt

def visualize_monte_carlo(initial_capital, drift, volatility, days, paths):
    """
    Simulates and visualizes Monte Carlo portfolio paths and Value at Risk (VaR).
    """
    # 1. Simulate the random paths using Geometric Brownian Motion
    daily_returns = np.random.normal(drift/days, volatility/np.sqrt(days), (days, paths))
    price_paths = np.zeros_like(daily_returns)
    price_paths[0] = initial_capital
    
    for t in range(1, days):
        price_paths[t] = price_paths[t-1] * (1 + daily_returns[t])

    final_values = price_paths[-1]
    
    # 2. Calculate the 95% Value at Risk threshold
    var_95_percentile = np.percentile(final_values, 5)

    # 3. Create the Visualization (Side-by-side plots)
    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 6))

    # --- Plot 1: The Simulation Paths ---
    ax1.plot(price_paths, alpha=0.2, color='blue', linewidth=1)
    ax1.set_title(f"Monte Carlo Simulation ({paths} Paths)")
    ax1.set_xlabel("Days")
    ax1.set_ylabel("Portfolio Value ($)")
    ax1.grid(True, alpha=0.3)
    # Highlight the starting capital
    ax1.axhline(initial_capital, color='black', linestyle='--', label='Initial Capital')
    ax1.legend()

    # --- Plot 2: The Final Distribution & VaR ---
    n, bins, patches = ax2.hist(final_values, bins=50, color='lightgray', edgecolor='black')
    
    # Highlight the worst 5% of outcomes (The VaR tail) in red
    for i in range(len(patches)):
        if bins[i] < var_95_percentile:
            patches[i].set_facecolor('red')
            patches[i].set_alpha(0.6)

    ax2.axvline(var_95_percentile, color='red', linestyle='dashed', linewidth=2, 
                label=f'95% VaR Threshold: ${var_95_percentile:,.0f}')
    ax2.set_title("Distribution of Final Portfolio Values")
    ax2.set_xlabel("Ending Value ($)")
    ax2.set_ylabel("Frequency")
    ax2.legend()

    plt.tight_layout()
    plt.show()

# --- Run the Visualization ---
if __name__ == "__main__":
    visualize_monte_carlo(
        initial_capital=100000, 
        drift=0.08,       # 8% expected annual return
        volatility=0.15,  # 15% annual volatility
        days=252,         # 1 trading year
        paths=500         # Number of simulated realities
    )
